# Real Data Configuration
# Rename this file to .env and fill in your keys

# Etherscan (Mainnet, Goerli, Sepolia)
# Get key at: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# BscScan (BNB Smart Chain)
# Get key at: https://bscscan.com/myapikey
BSCSCAN_API_KEY=

# PolygonScan (Polygon PoS)
# Get key at: https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=

# Optional: Pipeline Configuration
# PIPELINE_ADDRESS=0x...
# RISK_THRESHOLD=0.6
